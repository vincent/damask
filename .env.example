PORT=8080                      # http API server port
MAIL_PORT=2525                 # bundled mail server port
DB_PATH=./damask.db            # sqlite database path
BASE_URL=http://localhost:5173 # external URL pointing to the running app instance


# JWT salt secret, must be >= 32 chars
JWT_SECRET=change-me-to-a-long-random-secret

# Hash salt to encrypt credentials in db
APP_SECRET=change-me-to-a-long-random-secret

# Sending mails
SMTP_HOST= # host, or unix:// socket
SMTP_PORT=25
SMTP_SENDER=
SMTP_USER=
SMTP_PASS=

# Storage: local (default) | sftp | s3 | memory
STORAGE=local

# required when STORAGE=local
STORAGE_LOCAL_PATH=./storage # local storage path

# required when STORAGE=sftp
STORAGE_SFTP_HOST=
STORAGE_SFTP_PORT=22
STORAGE_SFTP_USER=
STORAGE_SFTP_AUTH_METHOD=password # password | key
STORAGE_SFTP_PASSWORD=
STORAGE_SFTP_BASE_PATH=/

# required when STORAGE=s3
STORAGE_S3_BASE_PATH=/
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESSKEY=
STORAGE_S3_SECRETKEY=

# Optional: Remove.bg API key for background removal
# REMOVEBG_API_KEY=

# Optional: Environment
APP_ENV=development

# Optional: Log level: INFO (default) | WARN | DEBUG
LOG_LEVEL=INFO

# Optional: Job scheduler is enabled if different than "false"
ENABLE_SCHEDULER=true

# Optional: Job workers
QUEUE_WORKERS=4

# Optional: use a specific ffmpeg binary instead of PATH lookup
FFMPEG_PATH=

# Optional: video decode hw accel hint. Supported: videotoolbox | vaapi | qsv | cuda
FFMPEG_HW_ACCEL=

# Development tracing only. Keep disabled in production env files.
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:8082/api/otel/v1
OTEL_TOKEN=dev-token

# Dev: Frontend URL
VITE_API_URL=http://localhost:8080

# Optional: To let users connect via Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: To let users connect via Canva
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Optional: To use ImageRouter for image processing
IMAGEROUTER_API_KEY=
IMAGEROUTER_DEFAULT_MODEL=black-forest-labs/FLUX-2-klein-4b:free
IMAGEROUTER_DEFAULT_BG_REMOVE_MODEL=bria/remove-background:free
IMAGEROUTER_RETRY_PAID_ON_FREE_LIMIT=false

# Text tracks / OCR
# Requires the Tesseract binary in PATH.
# Install: apt install tesseract-ocr tesseract-ocr-eng
# Additional languages: apt install tesseract-ocr-fra tesseract-ocr-spa

# Variant draft scratch cleanup — HH:MM UTC (default: 03:00)
SCRATCH_PURGE_TIME=03:00
