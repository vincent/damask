PORT=8080                      # http API server port
MAIL_PORT=2525                 # bundled mail server port
DB_PATH=./damask.db            # sqlite database path
BASE_URL=http://localhost:5173 # external URL pointing to the running app instance


# JWT salt secret, must be >= 32 chars
JWT_SECRET=change-me-to-a-long-random-secret

# Hash salt to encrypt credentials in db
APP_SECRET=change-me-to-a-long-random-secret

# Storage: local (default) | sftp
STORAGE=local

# required when STORAGE=local
STORAGE_PATH=./storage # local storage path

# required when STORAGE=sftp
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_AUTH_METHOD=password # password | key
SFTP_PASSWORD=
SFTP_BASE_PATH=/

# Optional: Remove.bg API key for background removal
# REMOVEBG_API_KEY=

# Optional: Environment
APP_ENV=development

# Optional: Log level: INFO (default) | WARN | DEBUG
LOG_LEVEL=INFO

# Optional: Job scheduler is enabled if different than "false"
ENABLE_SCHEDULER=true

# Optional: Job workers
QUEUE_WORKERS=4

# Dev: Frontend URL
VITE_API_URL=http://localhost:8080

